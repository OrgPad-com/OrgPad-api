    {
      "id": "488d2221-c45e-4a4a-9845-ed2ff00f5ed3",
      "pageId": "da5b1957-7d24-44f9-869e-9cebe27f7e67",
      "type": "math/math",
      "block": true,
      "source": "(x+y)^n = \\sum_{k=0}^n {n \\choose k} x^ky^{n-k}.",
      "width": 25.875,
